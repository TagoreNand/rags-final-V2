{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "RAG Ops v2 — API, worker, and pipeline observability",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Task Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active Tasks",
      "type": "stat",
      "targets": [
        { "expr": "rag_active_tasks", "legendFormat": "active", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "title": "Tasks by Status (total)",
      "type": "stat",
      "targets": [
        { "expr": "rag_tasks_total", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["mean"] } },
      "title": "Avg Task Duration (succeeded)",
      "type": "stat",
      "targets": [
        { "expr": "rate(rag_task_duration_seconds_sum{status='succeeded'}[5m]) / rate(rag_task_duration_seconds_count{status='succeeded'}[5m])", "legendFormat": "avg", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "title": "Task Throughput (per min)",
      "type": "stat",
      "targets": [
        { "expr": "rate(rag_tasks_total[1m]) * 60", "legendFormat": "tasks/min", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.3 } ] } } },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "title": "Task Failure Rate",
      "type": "stat",
      "targets": [
        { "expr": "rate(rag_tasks_total{status='failed'}[5m]) / rate(rag_tasks_total[5m])", "legendFormat": "failure rate", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "title": "Task Duration Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "title": "Task Duration Percentiles (succeeded)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_task_duration_seconds_bucket{status='succeeded'}[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, rate(rag_task_duration_seconds_bucket{status='succeeded'}[5m]))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(rag_task_duration_seconds_bucket{status='succeeded'}[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "title": "Task Rate by Status",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(rag_tasks_total{status='succeeded'}[1m])", "legendFormat": "succeeded/s", "refId": "A" },
        { "expr": "rate(rag_tasks_total{status='failed'}[1m])", "legendFormat": "failed/s", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "title": "LLM & Retrieval",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "title": "LLM Call Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_llm_latency_seconds_bucket[5m]))", "legendFormat": "p50 {{model}}", "refId": "A" },
        { "expr": "histogram_quantile(0.90, rate(rag_llm_latency_seconds_bucket[5m]))", "legendFormat": "p90 {{model}}", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(rag_llm_latency_seconds_bucket[5m]))", "legendFormat": "p99 {{model}}", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "title": "Retrieved Docs by Source (rate/min)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(rag_retrieval_docs_total[1m]) * 60", "legendFormat": "{{source}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rag-ops", "ai", "mlops"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Ops v2",
  "uid": "rag-ops-v2",
  "version": 1
}
