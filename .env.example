# ─── LLM (Ollama) ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBED_MODEL=nomic-embed-text

# ─── RAG tuning ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_MAX_SOURCES=6
MAX_STEPS=8

# ─── Multi-source retrieval ──────────────────────────────────────────────────
WIKI_SEARCH_ENDPOINT=https://en.wikipedia.org/w/api.php
WIKI_PAGE_SUMMARY_ENDPOINT=https://en.wikipedia.org/api/rest_v1/page/summary
SERPAPI_KEY=                    # optional – enables Google / Bing results
ARXIV_ENABLED=true              # academic paper retrieval
NEWS_API_KEY=                   # optional – NewsAPI.org
BRAVE_SEARCH_KEY=               # optional – Brave Search API (free tier)
MAX_WEB_FETCH_CHARS=25000
HTTP_TIMEOUT_S=20
HTTP_MAX_RETRIES=3

# ─── Agent execution ────────────────────────────────────────────────────────
ENABLE_CODE_RUN=false
MAX_CODE_RUN_SECONDS=20
CODE_SANDBOX=subprocess         # subprocess | docker | none

# ─── Worker queue (Redis-backed RQ) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=4
TASK_RESULT_TTL=86400           # seconds to keep results in Redis
JOB_TIMEOUT=300                 # hard kill after 5 min

# ─── Auth / API keys ────────────────────────────────────────────────────────
API_KEYS=dev-key-1,dev-key-2    # comma-separated; leave blank to disable auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=rag-ops
OTEL_ENABLED=false              # set true when collector is running
LOG_LEVEL=INFO
LOG_FORMAT=json                 # json | text

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/rag.db   # swap to postgres:// in prod

# ─── Advanced retrieval (ANN + hybrid fusion + rerank + query transform) ─────
RERANK_BACKEND=lexical          # none | lexical | llm | cross-encoder
RRF_K=60                        # Reciprocal Rank Fusion constant
HYBRID_ENABLED=true             # fuse BM25 with semantic via RRF
ANN_ENABLED=true                # hnswlib ANN when corpus is large enough
MULTI_QUERY_ENABLED=true        # fuse retrieval over supervisor query variants
HYDE_ENABLED=false              # Hypothetical Document Embeddings (1 extra LLM call)

# ─── Citation grounding + eval gate thresholds ──────────────────────────────
GROUNDING_ENABLED=true
GROUNDING_THRESHOLD=0.30
EVAL_MIN_RECALL_AT_5=0.80
EVAL_MIN_NDCG_AT_5=0.70
EVAL_MIN_MRR=0.70
EVAL_MIN_FAITHFULNESS=0.70
